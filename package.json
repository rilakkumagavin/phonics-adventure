{
  "name": "phonics-adventure",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "phase12:evidence": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-phase12-evidence.ps1",
    "phase12:evidence:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-phase12-evidence.ps1 -AllowIncomplete",
    "phase12:evidence:json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-phase12-evidence.ps1 -Json -AllowIncomplete",
    "phase12:audio:review": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/review-audio.ps1",
    "phase12:audio:dry-run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/review-audio.ps1 -DryRun",
    "phase12:audio:sync-manifests": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-audio-manifest-review.ps1",
    "phase12:audio:sync-manifests:dry-run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-audio-manifest-review.ps1 -DryRun",
    "phase12:audio:sync-manifests:json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-audio-manifest-review.ps1 -DryRun -Json",
    "phase12:device-server": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-device-test-server.ps1",
    "phase12:device-server:dry-run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-device-test-server.ps1 -DryRun",
    "phase12:device-form": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-device-workflow-form.ps1",
    "phase12:device-form:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-device-workflow-form.ps1 -AllowIncomplete",
    "phase12:device-form:json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-device-workflow-form.ps1 -Json -AllowIncomplete",
    "phase12:manual-ready": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-phase12-manual-acceptance.ps1",
    "phase12:manual-ready:json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-phase12-manual-acceptance.ps1 -Json",
    "phase12:auto-checks": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-phase12-automated-checks.ps1",
    "phase12:auto-checks:json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-phase12-automated-checks.ps1 -Json",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
